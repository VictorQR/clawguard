{
  "$schema": "https://openclaw.ai/schemas/plugin.json",
  "id": "clawguard",
  "name": "ClawGuard",
  "version": "0.1.0",
  "description": "Runtime tool call interception with command-level allow/deny/approve rules, bypass detection, file/network path rules, and audit logging",
  "author": "VictorQR",
  "license": "MIT",
  "entry": "dist/index.js",
  "activation": {
    "onStartup": true
  },
  "dependencies": {
    "node": ">=22"
  },
  "repository": "https://github.com/VictorQR/clawguard",
  "keywords": [
    "security",
    "interception",
    "audit",
    "clawguard"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "permissive",
          "supervised",
          "enforce"
        ],
        "default": "supervised",
        "description": "Security mode: permissive (log only), supervised (approval needed), enforce (block directly)"
      },
      "auditRetentionDays": {
        "type": "integer",
        "default": 90,
        "description": "Audit log retention in days"
      }
    }
  }
}